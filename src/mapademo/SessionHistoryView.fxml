<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="550.0" spacing="12.0" stylesheets="@../resources/estilos.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
   </padding>
   <children>
      <Label text="Session History">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <TableView fx:id="sessionTable" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colStart" prefWidth="90.0" text="Start" />
          <TableColumn fx:id="colEnd" prefWidth="90.0" text="End" />
            <TableColumn fx:id="colDur" prefWidth="90.0" text="Duration" />
            <TableColumn fx:id="colImported" prefWidth="70.0" text="Imported" />
            <TableColumn fx:id="colViewed" prefWidth="70.0" text="Viewed" />
            <TableColumn fx:id="colAnnotations" text="Annotations" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <HBox prefHeight="100.0" prefWidth="200.0" spacing="15.0" VBox.vgrow="ALWAYS">
         <children>
            <Label fx:id="lblTotalDur" text="Total duration:">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
               <HBox.margin>
                  <Insets right="40.0" />
               </HBox.margin>
            </Label>
         </children>
      </HBox>
      <HBox alignment="CENTER_RIGHT" prefHeight="26.0" prefWidth="499.0" VBox.vgrow="ALWAYS">
         <children>
            <Button alignment="CENTER" mnemonicParsing="false" onAction="#handleclose" prefHeight="35.0" prefWidth="100.0" styleClass="btn-cancel" text="Close" />
         </children>
      </HBox>
   </children>
</VBox>
